      "regular": { "$value": "400", "$description": "Normal/regular weight" },
      "medium": { "$value": "500", "$description": "Medium weight" },
      "semibold": { "$value": "600", "$description": "Semibold weight" },
      "bold": { "$value": "700", "$description": "Bold weight" },
      "extrabold": { "$value": "800", "$description": "Extra bold weight" },
      "black": { "$value": "900", "$description": "Black/heavy weight" }
    },
    "line-height": {
      "$type": "number",
      "none": { "$value": "1", "$description": "No extra leading — display text" },
      "tight": { "$value": "1.25", "$description": "Tight leading — headings" },
      "snug": { "$value": "1.375", "$description": "Snug leading — subheadings" },
      "normal": { "$value": "1.5", "$description": "Normal leading — body text" },
      "relaxed": { "$value": "1.625", "$description": "Relaxed leading — readable prose" },
      "loose": { "$value": "2", "$description": "Loose leading — spacious text" }
    },
    "letter-spacing": {
      "$type": "dimension",
      "tighter": { "$value": "-0.05em", "$description": "Tighter tracking" },
      "tight": { "$value": "-0.025em", "$description": "Tight tracking" },
      "normal": { "$value": "0em", "$description": "Normal tracking" },
      "wide": { "$value": "0.025em", "$description": "Wide tracking" },
      "wider": { "$value": "0.05em", "$description": "Wider tracking" },
      "widest": { "$value": "0.1em", "$description": "Widest tracking" }
    }
