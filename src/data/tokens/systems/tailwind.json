      "9xl": { "$value": "128px", "$description": "9XL — 8rem, line-height 1" }
    },
    "font-weight": {
      "$type": "fontWeight",
      "thin": { "$value": "100", "$description": "Thin weight" },
      "extralight": { "$value": "200", "$description": "Extra light weight" },
