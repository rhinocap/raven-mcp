    "$type": "dimension",
    "sm": { "$value": "640px", "$description": "Small — mobile landscape and up" },
    "md": { "$value": "768px", "$description": "Medium — tablet and up" },
    "lg": { "$value": "1024px", "$description": "Large — desktop and up" },
    "xl": { "$value": "1280px", "$description": "Extra large — wide desktop" },
    "2xl": { "$value": "1536px", "$description": "2XL — ultra-wide desktop" }
  },
