  "radius": {
    "$type": "dimension",
    "none": { "$value": "0px", "$description": "No rounding" },
    "sm": { "$value": "2px", "$description": "Small radius — 0.125rem" },
    "md": { "$value": "6px", "$description": "Default radius — 0.375rem" },
    "lg": { "$value": "8px", "$description": "Large radius — 0.5rem" },
    "xl": { "$value": "12px", "$description": "Extra large — 0.75rem" },
