  "typography": {
    "font-family": {
      "$type": "fontFamily",
      "sans": { "$value": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, \"Noto Sans\", sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\", \"Noto Color Emoji\"", "$description": "Default sans-serif stack" },
      "serif": { "$value": "ui-serif, Georgia, Cambria, \"Times New Roman\", Times, serif", "$description": "Serif font stack" },
      "mono": { "$value": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace", "$description": "Monospace font stack" }
    },
    "font-size": {
      "$type": "dimension",
      "xs": { "$value": "12px", "$description": "Extra small — 0.75rem, line-height 1rem" },
      "sm": { "$value": "14px", "$description": "Small — 0.875rem, line-height 1.25rem" },
      "base": { "$value": "16px", "$description": "Base — 1rem, line-height 1.5rem" },
      "lg": { "$value": "18px", "$description": "Large — 1.125rem, line-height 1.75rem" },
      "xl": { "$value": "20px", "$description": "XL — 1.25rem, line-height 1.75rem" },
      "2xl": { "$value": "24px", "$description": "2XL — 1.5rem, line-height 2rem" },
      "3xl": { "$value": "30px", "$description": "3XL — 1.875rem, line-height 2.25rem" },
      "4xl": { "$value": "36px", "$description": "4XL — 2.25rem, line-height 2.5rem" },
