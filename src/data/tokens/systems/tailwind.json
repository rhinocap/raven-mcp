    "duration": {
      "$type": "duration",
      "75": { "$value": "75ms", "$description": "Ultra-fast — color transitions" },
      "100": { "$value": "100ms", "$description": "Fast — hover states" },
      "150": { "$value": "150ms", "$description": "Quick — standard interactions" },
      "200": { "$value": "200ms", "$description": "Normal — default transitions" },
      "300": { "$value": "300ms", "$description": "Moderate — expanding elements" },
      "500": { "$value": "500ms", "$description": "Slow — complex animations" },
      "700": { "$value": "700ms", "$description": "Slower — page transitions" },
      "1000": { "$value": "1000ms", "$description": "Slowest — dramatic animations" }
    },
    "easing": {
      "$type": "cubicBezier",
      "linear": { "$value": [0, 0, 1, 1], "$description": "Linear — constant speed" },
      "in": { "$value": [0.4, 0, 1, 1], "$description": "Ease in — accelerating" },
      "out": { "$value": [0, 0, 0.2, 1], "$description": "Ease out — decelerating" },
      "in-out": { "$value": [0.4, 0, 0.2, 1], "$description": "Ease in-out — standard easing" }
    }
  },
  "opacity": {
    "$type": "number",
    "0": { "$value": "0", "$description": "Fully transparent" },
    "5": { "$value": "0.05", "$description": "Near transparent" },
    "10": { "$value": "0.1", "$description": "Very faint" },
    "20": { "$value": "0.2", "$description": "Faint" },
    "25": { "$value": "0.25", "$description": "Quarter opacity" },
    "30": { "$value": "0.3", "$description": "Light" },
    "40": { "$value": "0.4", "$description": "Medium-light" },
    "50": { "$value": "0.5", "$description": "Half opacity" },
    "60": { "$value": "0.6", "$description": "Medium" },
    "70": { "$value": "0.7", "$description": "Medium-strong" },
    "75": { "$value": "0.75", "$description": "Three-quarter opacity" },
    "80": { "$value": "0.8", "$description": "Strong" },
    "90": { "$value": "0.9", "$description": "Near opaque" },
    "95": { "$value": "0.95", "$description": "Almost fully opaque" },
