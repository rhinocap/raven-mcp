{
  "name": "raven-mcp",
  "version": "1.1.1",
  "description": "Design intelligence MCP server — accessibility, principles, patterns, tokens, and strategy for AI-generated UI. 73 design principles, 13 UI patterns, 13 tools, 12 design system tokens.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "raven-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "src/data/",
    "scripts/postinstall.cjs",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "postinstall": "node scripts/postinstall.cjs || true",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "resend": "^6.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "mcp",
    "design",
    "design-system",
    "tokens",
    "ux",
    "ui-patterns",
    "principles",
    "accessibility",
    "claude",
    "ai",
    "model-context-protocol"
  ],
  "author": "Andrew Cunliffe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rhinocap/raven-mcp"
  },
  "homepage": "https://ravenmcp.ai"
}
